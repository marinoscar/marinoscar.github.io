# This site's Gemfile pins `github-pages`, which locks Jekyll to ~3.9.x (the
# version GitHub Pages actually builds with). Testing against Jekyll 4 is
# therefore impossible here — its dependencies can never resolve alongside
# `github-pages` — so we only appraise the Jekyll version that ships.
appraise "jekyll-3" do
  gem "jekyll", "3.9.4"
end
